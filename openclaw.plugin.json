{
  "id": "instapaper-cli",
  "name": "Instapaper",
  "description": "Manage your Instapaper reading list: bookmarks, folders, highlights, tags, and article export",
  "requires": {
    "binaries": ["instapaper-cli"],
    "envVars": [
      { "name": "INSTAPAPER_CONSUMER_KEY", "required": true, "description": "Instapaper OAuth consumer key" },
      { "name": "INSTAPAPER_CONSUMER_SECRET", "required": true, "description": "Instapaper OAuth consumer secret" }
    ]
  },
  "skills": [
    "skills/instapaper"
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "consumerKey": {
        "oneOf": [
          {
            "type": "string",
            "description": "Instapaper OAuth consumer key (plaintext or env interpolation via ${VAR})"
          },
          {
            "type": "object",
            "description": "SecretRef for consumer key",
            "properties": {
              "source": {
                "type": "string",
                "enum": [
                  "env",
                  "file"
                ]
              },
              "provider": {
                "type": "string"
              },
              "id": {
                "type": "string"
              }
            },
            "required": [
              "source",
              "provider",
              "id"
            ]
          }
        ],
        "description": "Instapaper OAuth consumer key: plain string, ${ENV_VAR}, or SecretRef"
      },
      "consumerSecret": {
        "oneOf": [
          {
            "type": "string",
            "description": "Instapaper OAuth consumer secret (plaintext or env interpolation via ${VAR})"
          },
          {
            "type": "object",
            "description": "SecretRef for consumer secret",
            "properties": {
              "source": {
                "type": "string",
                "enum": [
                  "env",
                  "file"
                ]
              },
              "provider": {
                "type": "string"
              },
              "id": {
                "type": "string"
              }
            },
            "required": [
              "source",
              "provider",
              "id"
            ]
          }
        ],
        "description": "Instapaper OAuth consumer secret: plain string, ${ENV_VAR}, or SecretRef"
      }
    },
    "additionalProperties": false
  },
  "uiHints": {
    "consumerKey": {
      "label": "Consumer Key",
      "sensitive": true,
      "help": "Request at https://www.instapaper.com/main/request_oauth_consumer_token. Accepts a string, ${ENV_VAR}, or a SecretRef."
    },
    "consumerSecret": {
      "label": "Consumer Secret",
      "sensitive": true,
      "help": "Provided with your consumer key. Accepts a string, ${ENV_VAR}, or a SecretRef."
    }
  },
  "contracts": {
    "tools": [
      "instapaper_list",
      "instapaper_add",
      "instapaper_import",
      "instapaper_archive",
      "instapaper_unarchive",
      "instapaper_star",
      "instapaper_unstar",
      "instapaper_move",
      "instapaper_delete",
      "instapaper_text",
      "instapaper_folders_list",
      "instapaper_folders_add",
      "instapaper_folders_delete",
      "instapaper_highlights_list",
      "instapaper_highlights_add",
      "instapaper_tags_list"
    ]
  }
}
