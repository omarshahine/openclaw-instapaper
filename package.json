{
  "name": "instapaper-cli",
  "version": "1.1.0",
  "description": "OpenClaw plugin for Instapaper reading list management",
  "type": "module",
  "openclaw": {
    "extensions": ["./src/index.ts"],
    "compat": {
      "pluginApi": ">=2026.3.23"
    },
    "build": {
      "openclawVersion": "2026.3.28"
    }
  },
  "files": ["src/", "lib/", "skills/", "openclaw.plugin.json", "marketplace.json"],
  "keywords": ["openclaw", "openclaw-plugin", "instapaper", "reading-list", "bookmarks", "read-later"],
  "author": { "name": "Omar Shahine", "email": "omar@shahine.com" },
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/omarshahine/openclaw-instapaper.git" },
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=18" },
  "dependencies": {
    "openclaw": "^2026.3.23"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
